{
  "name": "ob-app",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "core/*",
    "services/*"
  ],
  "scripts": {
    "start:admin": "node services/admin/main.js",
    "start:staff": "node services/staff/main.js",
    "start:customer": "node services/customer/main.js",
    "start:mobile": "node services/mobile/main.js",
    "start:worker": "node services/ob-worker/main.js",
    "dev:admin": "node --watch services/admin/main.js",
    "dev:staff": "node --watch services/staff/main.js",
    "dev:customer": "node --watch services/customer/main.js",
    "dev:mobile": "node --watch services/mobile/main.js",
    "dev:worker": "node --watch services/ob-worker/main.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "bullmq": "^5.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "eslint": "^9.5.0",
    "eslint-plugin-n": "^17.9.0",
    "eslint-plugin-promise": "^6.4.0",
    "globals": "^17.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
